<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE aspectran PUBLIC "-//ASPECTRAN//DTD Aspectran 9.0//EN"
        "https://aspectran.com/dtd/aspectran-9.dtd">
<aspectran>

    <translet name="/echo">
        <transform format="text">
            <template>${msg}</template>
        </transform>
    </translet>

    <translet name="/world">
        <parameter name="world">World</parameter>
        <transform format="text">
            <template>@{hello} ${world}</template>
        </transform>
    </translet>

    <translet name="/include11">
        <include id="include" translet="/echo">
            <parameter name="msg">Hello</parameter>
        </include>
        <transform format="text">
            <template>@{include} World!</template>
        </transform>
    </translet>

    <translet name="/include12">
        <include translet="/echo">
            <parameter name="msg">Hello World</parameter>
        </include>
    </translet>

    <translet name="/include13">
        <include translet="/echo">
            <parameter name="msg">Hello World</parameter>
        </include>
    </translet>

    <translet name="/include21">
        <include id="include" translet="/world">
            <attribute name="hello">Hello</attribute>
        </include>
        <transform format="text">
            <template>@{include}!</template>
        </transform>
    </translet>

    <translet name="/include22">
        <include id="include" translet="/world">
            <attribute name="hello">Hello</attribute>
        </include>
        <transform format="text">
            <template>!</template>
        </transform>
    </translet>

    <translet name="/include23">
        <include id="include" translet="/world">
            <attribute name="hello">Hello</attribute>
        </include>
    </translet>

</aspectran>
