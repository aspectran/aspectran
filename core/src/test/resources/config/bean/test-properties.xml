<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE aspectran PUBLIC "-//ASPECTRAN//DTD Aspectran 9.0//EN"
        "https://aspectran.com/dtd/aspectran-9.dtd">
<aspectran>

    <bean id="properties" class="java.util.HashMap">
            <argument type="map">
                <entry name="property1">Property-1</entry>
                <entry name="property2">Property-2</entry>
                <entry name="property3">Property-3</entry>
            </argument>
    </bean>

	<environment profile="dev">
        <property name="env.property1">DEV-#{properties^property1}</property>
        <property name="env.property2">DEV-#{properties^property2}</property>
        <property name="env.property3">DEV-#{properties^property3}</property>
        <property name="env.property4">DEV-#{properties^property1} / #{properties^property2} / #{properties^property3}</property>
	</environment>

	<environment profile="prod">
        <property name="env.property1">PROD-#{properties^property1}</property>
        <property name="env.property2">PROD-#{properties^property2}</property>
        <property name="env.property3">PROD-#{properties^property3}</property>
        <property name="env.property4">PROD-#{properties^property1} / #{properties^property2} / #{properties^property3}</property>
	</environment>

    <template id="property-1" style="apon">
        |%{env.property1}
    </template>

    <template id="property-2" style="apon">
        |%{env.property2}
    </template>

    <template id="property-3" style="apon">
        |%{env.property3}
    </template>

    <template id="property-4" style="apon">
        |%{env.property4}
    </template>

</aspectran>