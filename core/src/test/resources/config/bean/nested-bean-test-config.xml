<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE aspectran PUBLIC "-//ASPECTRAN//DTD Aspectran 9.0//EN"
        "https://aspectran.com/dtd/aspectran-9.dtd">
<aspectran>

    <bean id="stringBean" class="java.lang.String" scope="prototype">
        <argument>String Bean</argument>
    </bean>

    <bean id="mapBean" class="java.util.HashMap" scope="prototype">
        <argument type="map">
            <entry name="item1">value1</entry>
            <entry name="item2">value2</entry>
        </argument>
    </bean>

        <bean id="mapBean2" class="java.util.HashMap" scope="prototype">
            <argument type="map">
                <entry name="ENTRY-1">
                    <bean id="mapBean" class="java.util.ArrayList" scope="prototype">
                        <argument type="list">
                            <bean class="java.lang.String">
                                <argument>ARG-1</argument>
                            </bean>
                            <bean class="java.lang.String">
                                <argument>ARG-2</argument>
                            </bean>
                        </argument>
                    </bean>
                </entry>
            </argument>
        </bean>

    <bean id="listBean" class="java.util.LinkedList" scope="prototype">
        <argument type="list">
            <value>value1</value>
            <value>value2</value>
        </argument>
    </bean>

    <bean id="nestedStringBean" class="java.lang.String" scope="prototype">
        <argument>
            <bean class="java.lang.String">
                    <argument>Nested String Bean</argument>
            </bean>
        </argument>
    </bean>

    <bean id="nestedStringBean-1" class="java.lang.String" scope="prototype">
        <argument>
            <bean class="java.lang.String">
                <argument>Nested String Bean</argument>
            </bean>
        </argument>
    </bean>

    <bean id="nestedStringBeanDepth3" class="java.lang.String" scope="prototype">
        <argument>
            <bean class="java.lang.String">
                <argument>
                    <bean class="java.lang.String">
                        <argument>Nested String Bean</argument>
                    </bean>
                </argument>
            </bean>
        </argument>
    </bean>

    <bean id="deepNestedStringBean" class="java.lang.String" scope="prototype">
        <argument>
            <bean class="java.lang.String">
                <argument>
                    <bean class="java.lang.String">
                        <argument>
                            <bean class="java.lang.String">
                                <argument>Nested String Bean</argument>
                            </bean>
                        </argument>
                    </bean>
                </argument>
            </bean>
        </argument>
    </bean>

</aspectran>
