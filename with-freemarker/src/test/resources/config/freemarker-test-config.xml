<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE aspectran PUBLIC "-//ASPECTRAN//DTD Aspectran 9.0//EN"
        "https://aspectran.com/dtd/aspectran-9.dtd">
<aspectran>

    <description>
        This is an Aspectran Configuration for Testing.
    </description>

    <settings>
        <setting name="defaultTemplateEngineBean" value="freemarker"/>
    </settings>

    <bean id="freemarker" class="com.aspectran.freemarker.FreeMarkerTemplateEngine">
        <argument>
            <bean class="com.aspectran.freemarker.ConfigurationFactoryBean">
                <property name="freemarkerSettings" type="properties">
                    <entry name="incompatible_improvements">2.3.23</entry>
                    <entry name="template_exception_handler">rethrow</entry>
                    <entry name="default_encoding">UTF-8</entry>
                    <entry name="number_format">0.####</entry>
                </property>
                <property name="templateLoaderPath" type="array">
                    <value>classpath:view/freemarker</value>
                </property>
                <property name="trimDirectives" valueType="parameters">
                    directive: {
                        name: "trim"
                    }
                    directive: {
                        name: "where"
                        prefix: "WHERE "
                        deprefixes: [
                            "and"
                            "or"
                        ]
                    }
                    directive: {
                        name: "set"
                        prefix: "SET "
                        desuffixes: ","
                    }
                </property>
            </bean>
        </argument>
    </bean>

    <bean id="freemarkerViewDispatcher" class="com.aspectran.freemarker.view.FreeMarkerViewDispatcher">
        <description>
            Register a FreeMarker View Dispatcher.
        </description>
        <argument>#{freemarker}</argument>
        <property name="suffix">.ftl</property>
    </bean>

    <translet name="echo-1">
        <parameter name="input_1">${input_1:12345}</parameter>
        <parameter name="input_2">${input_2:67890}</parameter>
        <transform format="text">
            <template engine="freemarker" style="apon">
                |${input_1}${input_2}
            </template>
        </transform>
    </translet>

    <template id="select-template" engine="freemarker" style="apon">
        <![CDATA[
        |SELECT
        |    '${name}' as name,
        |    '${email}' as email
        |FROM table1
        |<@directive.where>
        |    <#if id?has_content>
        |    id = :id
        |    </#if>
        |    <#if name?has_content>
        |    AND name = :name
        |    </#if>
        |    <#if email?has_content>
        |    AND email = :email
        |    </#if>
        |</@directive.where>
        |ORDER BY name
        ]]>
    </template>

    <template id="update-template" engine="freemarker" style="apon">
        <![CDATA[
        |UPDATE table1
        |<@directive.set>
        |    <#if name??>
        |    name = :name,
        |    </#if>
        |    <#if email??>
        |    email = :email,
        |    </#if>
        |    <#if id??>
        |    id = :id
        |    </#if>
        |</@directive.set>
        ]]>
    </template>

    <translet name="select-translet">
        <attribute name="name">${name:Jane}</attribute>
        <attribute name="email">${email:jane@mail.com}</attribute>
        <transform format="text">
            <template>~{select-template}</template>
        </transform>
    </translet>

    <translet name="update-translet-1">
        <attribute name="name">${name:Jane}</attribute>
        <attribute name="email">${email:jane@mail.com}</attribute>
        <transform format="text">
            <template>~{update-template}</template>
        </transform>
    </translet>

    <translet name="update-translet-2">
        <attribute name="name">${name:Jane}</attribute>
        <attribute name="email">${email:jane@mail.com}</attribute>
        <dispatch name="update-translet-2" dispatcher="freemarkerViewDispatcher"/>
    </translet>

</aspectran>
