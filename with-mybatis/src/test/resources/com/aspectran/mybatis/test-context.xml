<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE aspectran PUBLIC "-//ASPECTRAN//DTD Aspectran 9.0//EN"
        "https://aspectran.com/dtd/aspectran-9.dtd">
<aspectran>

    <bean id="dataSource" class="com.zaxxer.hikari.HikariDataSource" destroyMethod="close">
        <argument>
            <bean class="com.zaxxer.hikari.HikariConfig">
                <property name="driverClassName">org.h2.Driver</property>
                <property name="jdbcUrl">jdbc:h2:mem:testdb;MODE=MariaDB;AUTOCOMMIT=OFF;DB_CLOSE_DELAY=-1;INIT=RUNSCRIPT FROM 'classpath:com/aspectran/mybatis/test-schema.sql'</property>
                <property name="username">sa</property>
                <property name="password"></property>
            </bean>
        </argument>
    </bean>

    <bean id="sqlSessionFactory" class="com.aspectran.mybatis.SqlSessionFactoryBean">
        <property name="configLocation">classpath:com/aspectran/mybatis/mybatis-config.xml</property>
        <property name="environment">
            <bean class="org.apache.ibatis.mapping.Environment">
                <argument>test</argument>
                <argument>
                    <bean class="org.apache.ibatis.transaction.jdbc.JdbcTransactionFactory"/>
                </argument>
                <argument>#{dataSource}</argument>
            </bean>
        </property>
    </bean>

    <!-- Test SqlSessionAgent with dynamic routing enabled -->
    <bean id="testSqlSession" class="com.aspectran.mybatis.SqlSessionAgent">
        <argument>testTxAspect</argument>
        <argument>testReadOnlyTxAspect</argument>
        <property name="targetBeanId">testSqlSession</property>
        <property name="sqlSessionFactoryBeanId">sqlSessionFactory</property>
        <property name="isolationLevelAsString">READ_COMMITTED</property>
        <property name="readOnlyRollbackOnClose" valueType="boolean">true</property>
    </bean>

    <bean id="testSqlMapperProvider" class="com.aspectran.mybatis.TestSqlMapperProvider">
        <argument>#{testSqlSession}</argument>
    </bean>

    <!-- Test SqlSessionAgent with SERIALIZABLE isolation level -->
    <bean id="serializableSqlSession" class="com.aspectran.mybatis.SqlSessionAgent">
        <argument>serializableTxAspect</argument>
        <property name="targetBeanId">serializableSqlSession</property>
        <property name="sqlSessionFactoryBeanId">sqlSessionFactory</property>
        <property name="isolationLevelAsString">SERIALIZABLE</property>
    </bean>

    <bean id="serializableSqlMapperProvider" class="com.aspectran.mybatis.TestSqlMapperProvider">
        <argument>#{serializableSqlSession}</argument>
    </bean>

    <!-- Test SqlSessionAgent with single transaction (no routing) -->
    <bean id="singleSqlSession" class="com.aspectran.mybatis.SqlSessionAgent">
        <argument>singleTxAspect</argument>
        <property name="targetBeanId">singleSqlSession</property>
        <property name="sqlSessionFactoryBeanId">sqlSessionFactory</property>
    </bean>

    <bean id="singleSqlMapperProvider" class="com.aspectran.mybatis.TestSqlMapperProvider">
        <argument>#{singleSqlSession}</argument>
    </bean>

    <!-- Generic DAO beans -->
    <bean id="testDao" class="com.aspectran.mybatis.TestDao">
        <argument>#{testSqlMapperProvider}</argument>
    </bean>

    <bean id="serializableDao" class="com.aspectran.mybatis.TestDao">
        <argument>#{serializableSqlMapperProvider}</argument>
    </bean>

    <bean id="singleDao" class="com.aspectran.mybatis.TestDao">
        <argument>#{singleSqlMapperProvider}</argument>
    </bean>

</aspectran>
