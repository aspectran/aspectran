<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE aspectran PUBLIC "-//ASPECTRAN//DTD Aspectran 9.0//EN"
        "https://aspectran.com/dtd/aspectran-9.dtd">
<aspectran>

    <description>
        Configuration for database transactions
    </description>

    <environment>
        <property name="db.name.uuid">#{method:java.util.UUID^randomUUID}</property>
        <property name="db.name.suffix">%{uuid_random}</property>
        <properties profile="hibernate">
            <item name="petclinic.database.name">hibernate_test_%{db.name.suffix}</item>
        </properties>
        <properties profile="eclipselink">
            <item name="petclinic.database.name">eclipselink_test_%{db.name.suffix}</item>
        </properties>
    </environment>

    <bean id="dataSource" class="com.zaxxer.hikari.HikariDataSource" destroyMethod="close" lazyDestroy="true">
        <argument>
            <bean class="com.zaxxer.hikari.HikariConfig">
                <argument>
                    <bean class="com.aspectran.core.support.PropertiesFactoryBean">
                        <properties profile="h2">
                            <item name="locations" type="array">
                                <value>classpath:com/aspectran/jpa/common/db/h2/db.properties</value>
                            </item>
                        </properties>
                    </bean>
                </argument>
                <property name="poolName">datasource-%{petclinic.database.name}</property>
                <property name="registerMbeans" valueType="boolean">true</property>
            </bean>
        </argument>
    </bean>

    <bean id="readOnlyDataSource" class="com.zaxxer.hikari.HikariDataSource" destroyMethod="close" lazyDestroy="true">
        <argument>
            <bean class="com.zaxxer.hikari.HikariConfig">
                <argument>
                    <bean class="com.aspectran.core.support.PropertiesFactoryBean">
                        <properties profile="h2">
                            <item name="locations" type="array">
                                <value>classpath:com/aspectran/jpa/common/db/h2/db-readonly.properties</value>
                            </item>
                        </properties>
                    </bean>
                </argument>
                <property name="poolName">readonly-datasource-%{petclinic.database.name}</property>
                <property name="registerMbeans" valueType="boolean">true</property>
                <property name="readOnly" valueType="boolean">true</property>
            </bean>
        </argument>
    </bean>

</aspectran>
